<% if (!workout) { %>
  <!-- Graceful not found state -->
  <div class="text-center py-5">
    <i class="bi bi-exclamation-triangle-fill display-1 text-warning"></i>
    <h2 class="mt-3">Workout Not Found</h2>
    <p class="text-muted">That workout doesn't exist or may have been deleted.</p>
    <a href="/workouts" class="btn btn-primary mt-2">
      <i class="bi bi-arrow-left me-1"></i>Back to History
    </a>
  </div>

<% } else { %>

  <!-- Header -->
  <div class="d-flex align-items-start justify-content-between mb-4">
    <div class="d-flex align-items-center">
      <i class="bi bi-card-list display-5 text-info me-3"></i>
      <div>
        <h1 class="mb-0"><%= workout.name %></h1>
        <p class="text-muted mb-0">
          <i class="bi bi-calendar3 me-1"></i><%= workout.workout_date %>
        </p>
      </div>
    </div>

    <!-- Delete button -->
    <form action="/workouts/<%= workout.id %>?_method=DELETE" method="POST"
      onsubmit="return confirm('Delete this workout? This cannot be undone.')">
      <button type="submit" class="btn btn-outline-danger">
        <i class="bi bi-trash me-1"></i>Delete
      </button>
    </form>
  </div>

  <!-- Notes -->
  <% if (workout.notes) { %>
    <div class="alert alert-secondary mb-4">
      <i class="bi bi-chat-left-text me-2"></i><%= workout.notes %>
    </div>
  <% } %>

  <!-- Exercise sets table -->
  <% if (sets.length === 0) { %>
    <div class="card shadow-sm">
      <div class="card-body text-center py-4 text-muted">
        <i class="bi bi-journal-x display-4 mb-2"></i>
        <p class="mb-0">No exercise sets recorded for this workout.</p>
      </div>
    </div>
  <% } else { %>
    <div class="card shadow-sm mb-4">
      <div class="card-header fw-semibold">
        <i class="bi bi-list-ol me-2"></i>Exercises
      </div>
      <div class="table-responsive">
        <table class="table table-hover mb-0">
          <thead class="table-light">
            <tr>
              <th>Exercise</th>
              <th class="text-center">Sets</th>
              <th class="text-center">Reps</th>
              <th class="text-center">Weight (lbs)</th>
              <th class="text-center">Est. 1RM</th>
              <th class="text-center">PR</th>
            </tr>
          </thead>
          <tbody>
            <% sets.forEach(set => { %>
              <tr>
                <td class="fw-semibold"><%= set.exercise_name %></td>
                <td class="text-center"><%= set.sets %></td>
                <td class="text-center"><%= set.reps %></td>
                <td class="text-center"><%= set.weight_lbs %></td>
                <td class="text-center text-muted"><%= set.estimated_1rm %> lbs</td>
                <td class="text-center">
                  <% if (set.is_pr) { %>
                    <span class="badge badge-pr">
                      <i class="bi bi-trophy-fill me-1"></i>PR
                    </span>
                  <% } %>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  <% } %>

  <a href="/workouts" class="btn btn-outline-secondary">
    <i class="bi bi-arrow-left me-1"></i>Back to History
  </a>

<% } %>
